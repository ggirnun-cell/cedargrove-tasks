  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "dotenv": "16.4.5",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.6",
    "tsx": "4.16.2",
    "typescript": "5.5.3"
  }
